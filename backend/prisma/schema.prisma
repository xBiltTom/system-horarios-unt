generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS NUEVOS PARA CARGA NO LECTIVA Y FORMATOS
// ============================================================

enum TipoSede {
  CENTRAL
  DESCONCENTRADA
}

enum DedicacionDocente {
  TIEMPO_COMPLETO_40H
  DEDICACION_EXCLUSIVA_40H
  TIEMPO_PARCIAL_20H
  TIEMPO_PARCIAL_16H
  TIEMPO_PARCIAL_12H
  TIEMPO_PARCIAL_10H
  TIEMPO_PARCIAL_8H
}

enum TipoGrupo {
  UNICO_TEORIA
  UNICO_PRACTICA
  LABORATORIO_N
}

enum SeccionNoLectiva {
  PREPARACION_EVALUACION
  CONSEJERIA_TUTORIA
  INVESTIGACION
  CAPACITACION
  ACTIVIDADES_GOBIERNO
  ACTIVIDADES_ADMINISTRACION
  ASESORIA_TESIS
  RESPONSABILIDAD_SOCIAL
  COMITES_COMISIONES
}

enum EstadoDeclaracion {
  BORRADOR
  COMPLETADO
  VALIDADO
  PUBLICADO
}

enum TipoFormato {
  CARGA_HORARIA_CENTRAL
  DECLARACION_JURADA_CENTRAL
  CARGA_HORARIA_DESCONCENTRADA
  DECLARACION_JURADA_DESCONCENTRADA
  HORARIO_SEMANAL_DOCENTE
}

enum TipoPeriodo {
  I
  II
  III
}

// ============================================================
// 0. DATOS INSTITUCIONALES Y SEDES
// ============================================================

model datos_institucionales {
  id                     Int      @id @default(autoincrement())
  universidad            String   @db.VarChar(200)
  siglas_universidad     String   @db.VarChar(20)
  facultad               String   @db.VarChar(200)
  escuela                String   @db.VarChar(200)
  departamento_academico String   @db.VarChar(200)
  ciudad                 String   @db.VarChar(100)
  logo_url               String?  @db.VarChar(500)
  activo                 Boolean  @default(true)
  fecha_actualizacion    DateTime @default(now()) @db.Timestamp

  @@map("datos_institucionales")
}

model sede {
  id           Int      @id @default(autoincrement()) @map("id_sede")
  nombre       String   @db.VarChar(100)
  codigo       String   @unique @db.VarChar(20)
  tipo         TipoSede @default(CENTRAL)
  distrito     String?  @db.VarChar(100)
  provincia    String?  @db.VarChar(100)
  activo       Boolean  @default(true)

  docentes          docente[]
  ambientes         ambiente[]
  asignaciones_sede asignacion_sede[]
  bloques           bloque_horario[]
  periodos          periodo_academico[]

  @@map("sede")
}

// ============================================================
// 1. USUARIOS Y DOCENTES
// ============================================================

model usuario {
  id              Int       @id @default(autoincrement()) @map("id_usuario")
  email           String    @unique @db.VarChar(150)
  hash_contrasena String    @db.VarChar(255)
  rol             String    @db.VarChar(20)   // DIRECTOR, SECRETARIA, DOCENTE
  activo          Boolean   @default(true)
  fecha_creacion  DateTime  @default(now()) @db.Timestamp
  ultimo_acceso   DateTime? @db.Timestamp
  id_docente      Int?      @unique @map("id_docente")
  docente         docente?  @relation(fields: [id_docente], references: [id], onDelete: SetNull)

  bloques_registrados      bloque_horario[]                @relation("RegistradoPor")
  asignaciones_registradas asignacion_docente_componente[] @relation("AsignacionRegistradaPor")
  formatos_generados       formato_generado[]              @relation("GeneradoPor")

  @@map("usuario")
}

model docente {
  id                Int      @id @default(autoincrement()) @map("id_docente")
  codigo_ibm        String?  @unique @db.VarChar(20)
  dni               String?  @unique @db.VarChar(20)
  nombres           String   @db.VarChar(100)
  apellidos         String   @db.VarChar(100)
  email             String   @unique @db.VarChar(150)
  empleo            String?  @db.VarChar(150)
  telefono          String?  @db.VarChar(20)
  modalidad         String   @db.VarChar(20)   // NOMBRADO, CONTRATADO
  categoria         String   @db.VarChar(30)   // PRINCIPAL, ASOCIADO, AUXILIAR, JEFE_PRACTICA
  dedicacion        DedicacionDocente @default(TIEMPO_COMPLETO_40H)
  antiguedad        Int      @default(0)
  horas_max_semana  Int?                       // Límite legal (ej. 20, 24, 30). Null = sin límite
  id_sede_principal  Int?
  sede_principal     sede?    @relation(fields: [id_sede_principal], references: [id])
  activo            Boolean  @default(true)
  usuario           usuario?
  preferencias      preferencia_notificacion?
  asignaciones      asignacion_docente_componente[]
  bloques           bloque_horario[]
  disponibilidad    disponibilidad_docente[]
  atenciones        atencion_docente[]
  declaraciones     declaracion_carga[]
  carga_no_lectiva  carga_no_lectiva[]
  bloques_no_lectivos bloque_no_lectivo[]

  asignaciones_sede asignacion_sede[]
  formatos          formato_generado[]

  @@map("docente")
}

// ============================================================
// 2. PERÍODOS, CICLOS, CURSOS (CATÁLOGO)
// ============================================================

model periodo_academico {
  id              Int                @id @default(autoincrement()) @map("id_periodo")
  nombre          String             @unique @db.VarChar(20)   // "2026-I"
  tipo            TipoPeriodo        @default(I)
  fecha_inicio    DateTime           @db.Date
  fecha_fin       DateTime           @db.Date
  estado          String             @default("BORRADOR") @db.VarChar(20)
  activo          Boolean            @default(false) // Changed default to false since only one should be active
  id_sede         Int?
  sede            sede?              @relation(fields: [id_sede], references: [id])
  ciclos          ciclo[]
  ofertas         curso_oferta[]
  configuraciones configuracion[]
  ventanas        ventana_atencion[]
  bloques         bloque_horario[]
  declaraciones   declaracion_carga[]
  cargas_no_lectivas carga_no_lectiva[]
  bloques_no_lectivos bloque_no_lectivo[]

  asignaciones_sede asignacion_sede[]
  formatos        formato_generado[]

  @@map("periodo_academico")
}

model ciclo {
  id         Int               @id @default(autoincrement()) @map("id_ciclo")
  numero     Int               @db.SmallInt   // 1,2,3,...
  nombre     String?           @db.VarChar(50)
  periodo    periodo_academico @relation(fields: [id_periodo], references: [id])
  id_periodo Int               @map("id_periodo")
  ofertas    curso_oferta[]

  @@unique([id_periodo, numero])
  @@map("ciclo")
}

model curricula {
  id       Int      @id @default(autoincrement()) @map("id_curricula")
  codigo   String   @unique @db.VarChar(20)
  nombre   String   @db.VarChar(200)
  vigente  Boolean  @default(false)
  activo   Boolean  @default(true)
  cursos   curso[]

  @@map("curricula")
}

model curso {
  id            Int        @id @default(autoincrement()) @map("id_curso")
  nombre        String     @db.VarChar(150)
  codigo        String     @unique @db.VarChar(20)
  creditos      Int        @default(1)
  activo        Boolean    @default(true)
  id_curricula  Int?
  curricula     curricula? @relation(fields: [id_curricula], references: [id])
  ofertas       curso_oferta[]

  @@map("curso")
}

// ============================================================
// 3. OFERTA DEL CURSO EN UN PERÍODO (con tipo REGULAR/ELECTIVO)
// ============================================================

enum TipoCurso {
  REGULAR
  ELECTIVO
}

model curso_oferta {
  id          Int              @id @default(autoincrement()) @map("id_curso_oferta")
  periodo     periodo_academico @relation(fields: [id_periodo], references: [id])
  id_periodo  Int
  curso       curso            @relation(fields: [id_curso], references: [id])
  id_curso    Int
  ciclo       ciclo            @relation(fields: [id_ciclo], references: [id])
  id_ciclo    Int
  tipo_curso  TipoCurso        // REGULAR o ELECTIVO
  estado      String           @default("BORRADOR") // BORRADOR, ASIGNADO, PUBLICADO
  escuela_profesional String?  @db.VarChar(150)
  componentes curso_componente[]

  @@unique([id_periodo, id_curso, id_ciclo])
  @@map("curso_oferta")
}

// ============================================================
// 4. COMPONENTES DEL CURSO (TEORÍA, PRÁCTICA, LABORATORIO)
// ============================================================

enum TipoComponente {
  TEORIA
  PRACTICA
  LABORATORIO
}

model curso_componente {
  id                  Int                @id @default(autoincrement()) @map("id_componente")
  oferta              curso_oferta       @relation(fields: [id_oferta], references: [id])
  id_oferta           Int
  tipo                TipoComponente
  horas_requeridas    Int                // Total de horas a dictar en el periodo
  permite_multi_docente Boolean           @default(false) // true = repartible entre varios docentes
  grupos              grupo[]            // Grupos de este componente
  asignaciones        asignacion_docente_componente[]
  bloques             bloque_horario[]

  @@map("curso_componente")
}

// ============================================================
// 5. ASIGNACIÓN DE DOCENTES A COMPONENTES (CARGA HORARIA)
// ============================================================

model asignacion_docente_componente {
  id              Int            @id @default(autoincrement()) @map("id_asignacion_docente")
  componente      curso_componente @relation(fields: [id_componente], references: [id])
  id_componente   Int
  docente         docente        @relation(fields: [id_docente], references: [id])
  id_docente      Int
  horas_asignadas Int            // Horas que este docente cubrirá de este componente
  numero_alumnos  Int?
  id_registrado_por Int?
  registrado_por  usuario?       @relation("AsignacionRegistradaPor", fields: [id_registrado_por], references: [id])

  @@unique([id_componente, id_docente])
  @@map("asignacion_docente_componente")
}

// ============================================================
// 6. GRUPOS (ligados a un componente)
// ============================================================

model grupo {
  id              Int            @id @default(autoincrement()) @map("id_grupo")
  componente      curso_componente @relation(fields: [id_componente], references: [id])
  id_componente   Int
  codigo          String         @db.VarChar(10)  // "UNICO", "A", "B", "C"
  tipo_grupo      TipoGrupo      @default(UNICO_TEORIA)
  capacidad_maxima Int           @default(40)
  activo          Boolean        @default(true)
  bloques         bloque_horario[]

  @@unique([id_componente, codigo])
  @@map("grupo")
}

// ============================================================
// 7. BLOQUE HORARIO (con soporte para solicitudes de aula)
// ============================================================

model bloque_horario {
  id              Int               @id @default(autoincrement()) @map("id_bloque_horario")
  periodo         periodo_academico @relation(fields: [id_periodo], references: [id])
  id_periodo      Int
  componente      curso_componente  @relation(fields: [id_componente], references: [id])
  id_componente   Int
  docente         docente           @relation(fields: [id_docente], references: [id])
  id_docente      Int
  ambiente        ambiente?         @relation(fields: [id_ambiente], references: [id]) // Ahora opcional
  id_ambiente     Int?              // Puede ser nulo si es una solicitud
  grupo           grupo             @relation(fields: [id_grupo], references: [id])
  id_grupo        Int
  dia_semana      String            @db.VarChar(15)   // LUNES, MARTES, ...
  hora_inicio     String            @db.VarChar(5)    // "08:00"
  hora_fin        String            @db.VarChar(5)    // "10:00"
  estado          String            @default("BORRADOR") // BORRADOR, CONFIRMADO, PUBLICADO, PENDIENTE_AMBIENTE
  comentario      String?           @db.Text
  pendiente_ambiente Boolean         @default(false)  // NUEVO CAMPO: true = esperando asignación de aula
  id_registrado_por Int?
  registrado_por  usuario?          @relation("RegistradoPor", fields: [id_registrado_por], references: [id])
  es_sede_desconcentrada Boolean     @default(false)
  id_sede         Int?
  sede            sede?             @relation(fields: [id_sede], references: [id])
  fecha_modificacion DateTime        @default(now()) @db.Timestamp

  // Índices para búsquedas rápidas (las validaciones de solapamiento van en backend)
  @@index([id_periodo, id_docente, dia_semana])
  @@index([id_periodo, id_ambiente, dia_semana])
  @@index([id_periodo, id_grupo, dia_semana])
  @@index([id_periodo, id_componente])
  @@map("bloque_horario")
}

// ============================================================
// 8. AMBIENTES (AULAS / LABORATORIOS)
// ============================================================

model ambiente {
  id               Int                @id @default(autoincrement()) @map("id_ambiente")
  codigo           String             @unique @db.VarChar(100)
  tipo             String             @db.VarChar(20)   // AULA, LABORATORIO
  capacidad        Int                @default(40)
  piso             Int?
  equipamiento     String?            @db.Text
  activo           Boolean            @default(true)
  id_sede          Int?
  sede             sede?              @relation(fields: [id_sede], references: [id])
  bloques          bloque_horario[]
  disponibilidad   disponibilidad_ambiente[]
  mantenimientos   mantenimiento[]

  @@map("ambiente")
}

model disponibilidad_ambiente {
  id          Int      @id @default(autoincrement()) @map("id_disponibilidad_ambiente")
  ambiente    ambiente @relation(fields: [id_ambiente], references: [id], onDelete: Cascade)
  id_ambiente Int      @map("id_ambiente")
  dia_semana  String   @db.VarChar(15)
  hora_inicio String   @db.VarChar(5)
  hora_fin    String   @db.VarChar(5)
  disponible  Boolean  @default(true)

  @@map("disponibilidad_ambiente")
}

// ============================================================
// 9. DISPONIBILIDAD DE DOCENTES (declarativa)
// ============================================================

model disponibilidad_docente {
  id          Int     @id @default(autoincrement()) @map("id_disponibilidad")
  docente     docente @relation(fields: [id_docente], references: [id], onDelete: Cascade)
  id_docente  Int     @map("id_docente")
  dia_semana  String  @db.VarChar(15)
  hora_inicio String  @db.VarChar(5)
  hora_fin    String  @db.VarChar(5)
  disponible  Boolean @default(true)

  @@map("disponibilidad_docente")
}

// ============================================================
// 11. CARGA NO LECTIVA, HORARIO PERSONAL Y FORMATOS
// ============================================================

model declaracion_carga {
  id                      Int               @id @default(autoincrement()) @map("id_declaracion")
  id_docente              Int
  docente                 docente           @relation(fields: [id_docente], references: [id])
  id_periodo              Int
  periodo                 periodo_academico @relation(fields: [id_periodo], references: [id])
  total_horas_lectivas    Int               @default(0)
  total_horas_no_lectivas Int               @default(0)
  total_horas             Int               @default(0)
  estado                  EstadoDeclaracion @default(BORRADOR)
  fecha_declaracion       DateTime          @default(now()) @db.Timestamp
  fecha_validacion        DateTime?         @db.Timestamp
  validado_por            String?           @db.VarChar(100)
  observaciones           String?           @db.Text

  secciones       carga_no_lectiva[]

  formatos        formato_generado[]

  @@unique([id_docente, id_periodo])
  @@map("declaracion_carga")
}

model carga_no_lectiva {
  id                  Int               @id @default(autoincrement()) @map("id_carga_no_lectiva")
  id_declaracion      Int
  declaracion         declaracion_carga  @relation(fields: [id_declaracion], references: [id], onDelete: Cascade)
  id_docente          Int
  docente             docente           @relation(fields: [id_docente], references: [id])
  id_periodo          Int
  periodo             periodo_academico  @relation(fields: [id_periodo], references: [id])
  seccion             SeccionNoLectiva
  descripcion         String?           @db.Text
  horas_declaradas    Int               @default(0)
  codigo_resolucion   String?           @db.VarChar(50)
  valido              Boolean           @default(true)
  observacion         String?           @db.Text
  fecha_registro      DateTime          @default(now()) @db.Timestamp
  fecha_modificacion  DateTime          @default(now()) @db.Timestamp

  @@unique([id_declaracion, seccion])
  @@index([id_docente, id_periodo])
  @@map("carga_no_lectiva")
}

model bloque_no_lectivo {
  id              Int               @id @default(autoincrement()) @map("id_bloque_no_lectivo")
  id_periodo      Int
  periodo         periodo_academico @relation(fields: [id_periodo], references: [id])
  id_docente      Int
  docente         docente           @relation(fields: [id_docente], references: [id])
  seccion         SeccionNoLectiva
  dia_semana      String            @db.VarChar(15)
  hora_inicio     String            @db.VarChar(5)
  hora_fin        String            @db.VarChar(5)
  estado          String            @default("BORRADOR") @db.VarChar(20)
  fecha_modificacion DateTime       @default(now()) @db.Timestamp

  @@index([id_docente, id_periodo, dia_semana])
  @@map("bloque_no_lectivo")
}


model asignacion_sede {
  id                        Int               @id @default(autoincrement()) @map("id_asignacion_sede")
  id_docente                Int
  docente                   docente           @relation(fields: [id_docente], references: [id])
  id_periodo                Int
  periodo                   periodo_academico @relation(fields: [id_periodo], references: [id])
  id_sede                   Int
  sede                      sede              @relation(fields: [id_sede], references: [id])
  numero_comision_servicios String?           @db.VarChar(50)
  fecha_inicio              DateTime?         @db.Date
  fecha_fin                 DateTime?         @db.Date
  activo                    Boolean           @default(true)

  @@unique([id_docente, id_periodo, id_sede])
  @@map("asignacion_sede")
}

model formato_generado {
  id               Int               @id @default(autoincrement()) @map("id_formato")
  id_docente       Int
  docente          docente           @relation(fields: [id_docente], references: [id])
  id_periodo       Int
  periodo          periodo_academico @relation(fields: [id_periodo], references: [id])
  id_declaracion   Int?
  declaracion      declaracion_carga? @relation(fields: [id_declaracion], references: [id])
  tipo_formato     TipoFormato
  ruta_archivo     String?           @db.VarChar(500)
  fecha_generacion DateTime          @default(now()) @db.Timestamp
  id_generado_por  Int?
  generado_por     usuario?          @relation("GeneradoPor", fields: [id_generado_por], references: [id])

  @@unique([id_docente, id_periodo, tipo_formato])
  @@index([id_docente, id_periodo])
  @@map("formato_generado")
}

// 12. AUDITORÍA Y CONFIGURACIÓN (opcionales)
// 10. VENTANAS DE ATENCIÓN Y ASIGNACIÓN DE TURNOS
// ============================================================

model ventana_atencion {
  id          Int                @id @default(autoincrement()) @map("id_ventana")
  periodo     periodo_academico  @relation(fields: [id_periodo], references: [id])
  id_periodo  Int
  fecha       DateTime           @db.Date
  hora_inicio String             @db.VarChar(5)
  hora_fin    String             @db.VarChar(5)
  categoria   String             @db.VarChar(30)   // PRINCIPAL, ASOCIADO, ...
  modalidad   String             @db.VarChar(20)   // NOMBRADO, CONTRATADO
  orden       Int                                 // orden dentro del día
  estado      String             @default("PENDIENTE") @db.VarChar(20)
  atenciones  atencion_docente[]

  @@map("ventana_atencion")
}

model atencion_docente {
  id           Int              @id @default(autoincrement()) @map("id_atencion")
  ventana      ventana_atencion @relation(fields: [id_ventana], references: [id])
  id_ventana   Int
  docente      docente          @relation(fields: [id_docente], references: [id])
  id_docente   Int
  estado       String           @default("PENDIENTE") @db.VarChar(20) // PENDIENTE, EN_PROGRESO, COMPLETADO
  orden_espera Int

  @@unique([id_ventana, id_docente])
  @@map("atencion_docente")
}

// ============================================================
// 11. AUDITORÍA Y CONFIGURACIÓN (opcionales)
// ============================================================

model auditoria_horario {
  id               Int      @id @default(autoincrement()) @map("id_auditoria")
  id_bloque_horario Int?               // referencia a bloque_horario.id
  tipo_accion      String   @db.VarChar(30) // CREAR, MODIFICAR, ELIMINAR
  usuario          String   @db.VarChar(100)
  fecha            DateTime @default(now()) @db.Timestamp
  detalle          String   @db.Text
  datos_anteriores Json?

  @@map("auditoria_horario")
}

model configuracion {
  id         Int               @id @default(autoincrement()) @map("id_configuracion")
  periodo    periodo_academico @relation(fields: [id_periodo], references: [id])
  id_periodo Int
  clave      String            @db.VarChar(50)   // FRANJA_INICIO, HORAS_MAX_DIARIAS, ...
  valor      String            @db.Text
  tipo       String            @default("TEXTO") @db.VarChar(20)

  @@unique([id_periodo, clave])
  @@map("configuracion")
}

// ============================================================
// 12. NOTIFICACIONES (opcional, se mantiene)
// ============================================================

model preferencia_notificacion {
  id                  Int     @id @default(autoincrement()) @map("id_preferencia")
  docente             docente @relation(fields: [id_docente], references: [id], onDelete: Cascade)
  id_docente          Int     @unique
  correo_habilitado   Boolean @default(true)
  whatsapp_habilitado Boolean @default(false)
  telegram_habilitado Boolean @default(false)
  whatsapp_verificado Boolean @default(false)
  telegram_id         String? @db.VarChar(50)

  @@map("preferencia_notificacion")
}

model historial_notificacion {
  id           Int      @id @default(autoincrement()) @map("id_historial")
  id_docente   Int
  canal        String   @db.VarChar(20)
  tipo_mensaje String   @db.VarChar(50)
  estado_envio String   @db.VarChar(20)
  fecha_envio  DateTime @default(now()) @db.Timestamp
  contenido    String?  @db.Text
  reintentos   Int      @default(0)

  @@index([id_docente, fecha_envio])
  @@map("historial_notificacion")
}

model cola_notificacion {
  id           Int       @id @default(autoincrement()) @map("id_cola")
  id_docente   Int
  canal        String    @db.VarChar(20)
  tipo_mensaje String    @db.VarChar(50)
  contenido    String    @db.Text
  estado       String    @default("PENDIENTE") @db.VarChar(20)
  creado_en    DateTime  @default(now()) @db.Timestamp
  procesado_en DateTime?

  @@index([estado, creado_en])
  @@map("cola_notificacion")
}

// ============================================================
// 13. MANTENIMIENTO DE AMBIENTES Y DÍAS NO LABORABLES
// ============================================================

model mantenimiento {
  id           Int      @id @default(autoincrement()) @map("id_mantenimiento")
  ambiente     ambiente @relation(fields: [id_ambiente], references: [id])
  id_ambiente  Int
  fecha_inicio DateTime @db.Timestamp
  fecha_fin    DateTime @db.Timestamp
  descripcion  String?  @db.Text

  @@map("mantenimiento")
}

model dia_no_laborable {
  id          Int      @id @default(autoincrement()) @map("id_dia_no_laborable")
  fecha       DateTime @db.Date
  descripcion String   @db.VarChar(200)
